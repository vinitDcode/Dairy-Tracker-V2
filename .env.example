# ═══════════════════════════════════════════════════════════
# DAIRY TRACKER V2 - ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values

# ─────────────────────────────────────────────────────────
# DATABASE (Required - PostgreSQL)
# ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dairy_tracker_v2

# ─────────────────────────────────────────────────────────
# SUPABASE (Frontend - Safe to expose)
# ─────────────────────────────────────────────────────────
# These are already in public/supabase-config.js but can override here
NEXT_PUBLIC_SUPABASE_URL=https://gmywodybfbcztnbrfnnr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_eq-19H8bApV3kmKOcr2IBw_hmw73jUI

# ─────────────────────────────────────────────────────────
# BETTER AUTH (Authentication - Required)
# ─────────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your_generated_32_char_secret_here_min_32_chars
BETTER_AUTH_URL=https://localhost:3000

# ─────────────────────────────────────────────────────────
# BUILD & RUNTIME
# ─────────────────────────────────────────────────────────
NODE_ENV=development
CI=false

# ─────────────────────────────────────────────────────────
# OPTIONAL: Telemetry
# ─────────────────────────────────────────────────────────
# SUPERPOWERS_DISABLE_TELEMETRY=false
# DISABLE_TELEMETRY=false
